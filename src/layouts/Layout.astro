---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
    title?: string;
    isHome?: boolean;
}

const { title = "Organic Blue", isHome = false } = Astro.props;
---

<html lang="en" transition:animate="none">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
        {/* On the initial hard load, pre-hide the navbar tiles so they flicker
           in cleanly with the rest of the interface instead of painting first.
           The class is dropped after the first sweep; later navigations keep
           persistent tiles visible and only diff what changed. */}
        <script is:inline>
            document.documentElement.classList.add("nav-boot");
            // Homepage intro: on the first hard load of "/", start with the
            // navbar tucked off-screen behind a click-to-enter overlay. Set
            // before first paint so neither flashes.
            if (location.pathname === "/") {
                document.documentElement.classList.add("home-intro");
            }
        </script>
        <style>
            html.nav-boot [data-nav-flicker] {
                opacity: 0;
            }
        </style>
        {/* Content flickers in via the shared flicker language; keep flicker
           elements visible when JS is unavailable. */}
        <noscript>
            <style>
                [data-flicker],
                [data-fade-in],
                [data-text-reveal],
                html.nav-boot [data-nav-flicker] {
                    opacity: 1 !important;
                }
            </style>
        </noscript>
        <script>
            import "@mux/mux-player";
            import "../scripts/flicker";

            // Homepage intro: while `home-intro` is set (hard load of "/"), the
            // navbar is hidden behind the click-to-enter overlay. Reveal it on
            // the first click anywhere; clear the state when navigating away
            // (the class lives on <html>, which survives client-side nav).
            document.addEventListener("astro:page-load", () => {
                const html = document.documentElement;
                if (
                    location.pathname === "/" &&
                    html.classList.contains("home-intro")
                ) {
                    window.addEventListener(
                        "click",
                        () => html.classList.remove("home-intro"),
                        { once: true },
                    );
                } else {
                    html.classList.remove("home-intro");
                }
            });
        </script>
    </head>
    <body data-page={isHome ? "home" : "inner"}>
        <Navbar />
        <slot />
    </body>
</html>
