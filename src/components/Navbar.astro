</nav>

{
    /* White dimming layer shown while the cart is open. Sits above page content
   but below the nav (which is lifted above it), so only cart UI stays crisp.
   Clicking it closes the cart. */
}
<div
    id="cart-overlay"
    class="fixed inset-0 z-40 hidden bg-white/50 backdrop-blur-sm"
>
</div>

{
    /* Cart panel: item cards + checkout button. Fixed and positioned by JS so it
   floats directly above the Shop button without pushing any navbar rows. Only
   shown while the cart is open. */
}
<div
    id="cart-panel"
    data-shop-domain={storeDomain}
    class="fixed z-50 hidden flex-col gap-0.5 text-xs text-grey"
>
</div>

<style>
    /* While the cart is open, every non-cart nav element gets a matching
       white/blur veil so only the cart UI reads as active. */
    #navbar.cart-open .cart-dim {
        position: relative;
    }
    #navbar.cart-open .cart-dim::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: rgb(255 255 255 / 0.5);
        backdrop-filter: blur(2px);
        pointer-events: none;
    }
</style>

<script>
    // Broadcast filter changes so the explorations WebScene can react.
    document.addEventListener("astro:page-load", () => {
        const fieldset = document.getElementById("exp-filters");
        if (!fieldset) return;

        fieldset.addEventListener("change", (e) => {
            const target = e.target as HTMLInputElement;
            if (target.name !== "exp-filter") return;
            window.dispatchEvent(
                new CustomEvent("filter:change", {
                    detail: { category: target.value },
                }),
            );
        });
    });
</script>

<script>
    import { flicker, flickerOut } from "../scripts/flicker";

    // ---- Cart ---------------------------------------------------------------
    // Client-side cart persisted in localStorage. The navbar is re-rendered per
    // page (Astro), so on every page load we rebuild the cart UI from storage
    // and re-wire the add-to-cart buttons that live on product pages.

    type CartItem = {
        slug: string;
        variantId: string; // numeric Shopify variant id, for the checkout link
        name: string;
        priceAmount: number;
        priceCurrency: string;
        image: string;
        qty: number;
    };

    const STORAGE_KEY = "ob-cart";
    const GAP = 2; // px, matches the nav's gap-0.5
    let cartOpen = false;

    const readCart = (): CartItem[] => {
        try {
            const raw = localStorage.getItem(STORAGE_KEY);
            return raw ? (JSON.parse(raw) as CartItem[]) : [];
        } catch {
            return [];
        }
    };

    const writeCart = (items: CartItem[]) => {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
    };

    // "590 CAD" -> { amount: 590, currency: "CAD" }
    const parsePrice = (display: string) => {
        const match = display.trim().match(/([\d.,]+)\s*(\S+)?/);
        const amount = match ? Number(match[1].replace(/,/g, "")) : 0;
        const currency = match && match[2] ? match[2] : "";
        return { amount: isNaN(amount) ? 0 : amount, currency };
    };

    const formatMoney = (amount: number, currency: string) =>
        `${Math.round(amount)}${currency ? " " + currency : ""}`;

    const addToCart = (data: {
        slug: string;
        variantId: string;
        name: string;
        price: string;
        image: string;
    }) => {
        const items = readCart();
        const existing = items.find((i) => i.slug === data.slug);
        if (existing) {
            existing.qty += 1;
        } else {
            const { amount, currency } = parsePrice(data.price);
            items.push({
                slug: data.slug,
                variantId: data.variantId,
                name: data.name,
                priceAmount: amount,
                priceCurrency: currency,
                image: data.image,
                qty: 1,
            });
        }
        writeCart(items);
        // Adding an item pops the cart open (and flickers it in via setOpen).
        setOpen(true);
    };

    const removeFromCart = (slug: string) => {
        writeCart(readCart().filter((i) => i.slug !== slug));
        render();
    };

    const setOpen = (open: boolean) => {
        const panel = document.getElementById("cart-panel");

        // Closing: blink the cards/checkout out first, then tear the panel down.
        if (!open && panel && panel.children.length > 0) {
            flickerOut(Array.from(panel.children), () => {
                cartOpen = false;
                render();
            });
            return;
        }

        cartOpen = open;
        render();
        // Opening: blink the cart in with the shared flicker language. The panel
        // + its cards/checkout are built fresh by render() each time, so this
        // catches whatever is currently shown.
        if (open && panel) flicker(panel.children, { step: 0.07 });
    };

    // Build one cart item card matching the spec: 3-col grid, image / title +
    // quantity / price + remove, everything top-aligned.
    const buildCard = (item: CartItem) => {
        const card = document.createElement("div");
        card.className =
            "cart-item w-full grid grid-cols-3 gap-2 items-start p-2 rounded-xs bg-black text-grey";

        const imgCol = document.createElement("div");
        if (item.image) {
            const img = document.createElement("img");
            img.src = item.image;
            img.alt = item.name;
            img.className = "w-full h-full object-cover rounded-xs";
            imgCol.appendChild(img);
        }

        const infoCol = document.createElement("div");
        infoCol.className = "flex flex-col";
        const nameEl = document.createElement("p");
        nameEl.textContent = item.name;
        const qtyEl = document.createElement("p");
        qtyEl.textContent = `Quantity: ${item.qty}`;
        infoCol.append(nameEl, qtyEl);

        const priceCol = document.createElement("div");
        priceCol.className = "flex flex-col items-end text-right";
        const priceEl = document.createElement("p");
        priceEl.textContent = formatMoney(
            item.priceAmount * item.qty,
            item.priceCurrency,
        );
        const removeEl = document.createElement("button");
        removeEl.type = "button";
        removeEl.className =
            "opacity-50 transition-opacity hover:opacity-100 cursor-pointer";
        removeEl.textContent = "Remove";
        removeEl.addEventListener("click", () => removeFromCart(item.slug));
        priceCol.append(priceEl, removeEl);

        card.append(imgCol, infoCol, priceCol);
        return card;
    };

    const buildCheckout = (items: CartItem[]) => {
        const currency = items[0]?.priceCurrency ?? "";
        const total = items.reduce((sum, i) => sum + i.priceAmount * i.qty, 0);
        const btn = document.createElement("button");
        btn.id = "cart-checkout";
        btn.type = "button";
        btn.className =
            "flex items-center justify-between w-full px-1 py-1 rounded-xs h-6.5 bg-black text-grey transition-colors hover:bg-grey hover:text-black";
        const label = document.createElement("span");
        label.textContent = "Checkout";
        const totalEl = document.createElement("span");
        totalEl.textContent = formatMoney(total, currency);
        btn.append(label, totalEl);

        // Hand off to Shopify's hosted checkout via a cart permalink:
        //   https://{store}/cart/{variantId}:{qty},{variantId}:{qty}
        // which loads a fresh cart with these lines and lands on checkout.
        btn.addEventListener("click", () => {
            const domain =
                document.getElementById("cart-panel")?.dataset.shopDomain;
            const lines = items
                .filter((i) => i.variantId)
                .map((i) => `${i.variantId}:${i.qty}`)
                .join(",");
            if (!domain || !lines) return;
            window.location.href = `https://${domain}/cart/${lines}`;
        });
        return btn;
    };

    // Float the panel directly above the Shop button: same left/width, its
    // bottom edge one gap above the button's top. Fixed positioning means it
    // never pushes the navbar rows around.
    const positionPanel = () => {
        const panel = document.getElementById("cart-panel");
        const shopNav = document.getElementById("shop-nav");
        if (!panel || !shopNav || !cartOpen) return;
        const rect = shopNav.getBoundingClientRect();
        panel.style.left = `${rect.left}px`;
        panel.style.width = `${rect.width}px`;
        panel.style.bottom = `${window.innerHeight - rect.top + GAP}px`;
    };

    const render = () => {
        const nav = document.getElementById("navbar");
        const panel = document.getElementById("cart-panel");
        const count = document.getElementById("cart-count");
        const shopNav = document.getElementById("shop-nav");
        const label = document.getElementById("shop-nav-label");
        const overlay = document.getElementById("cart-overlay");
        if (!nav || !panel || !count || !shopNav || !label || !overlay) return;

        const items = readCart();
        const totalQty = items.reduce((sum, i) => sum + i.qty, 0);

        // Empty cart resets everything back to a plain Shop button.
        if (totalQty === 0) cartOpen = false;

        // Count badge on the Shop button. Shows the item count when closed and
        // an ✕ (close affordance) while the cart is open.
        count.textContent = cartOpen ? "✕" : String(totalQty);
        count.classList.toggle("hidden", totalQty === 0);
        count.classList.toggle("inline-flex", totalQty > 0);
        shopNav.classList.toggle("justify-between", totalQty > 0);

        // Panel contents (item cards + checkout), only built while open.
        panel.replaceChildren();
        if (cartOpen && totalQty > 0) {
            items.forEach((item) => panel.appendChild(buildCard(item)));
            panel.appendChild(buildCheckout(items));
        }

        // Open state: reveal panel + overlay, dim the rest, swap label to "Cart".
        label.textContent = cartOpen ? "Cart" : "Shop";
        nav.classList.toggle("cart-open", cartOpen);
        overlay.classList.toggle("hidden", !cartOpen);
        panel.classList.toggle("hidden", !cartOpen);
        panel.classList.toggle("flex", cartOpen);
        nav.style.zIndex = cartOpen ? "50" : "";
        positionPanel();
    };

    const wire = () => {
        // Fresh page — start with the cart closed.
        cartOpen = false;

        // Add-to-cart buttons live on product pages.
        document
            .querySelectorAll<HTMLElement>("[data-add-to-cart]")
            .forEach((el) => {
                if (el.dataset.cartWired) return;
                el.dataset.cartWired = "1";
                el.addEventListener("click", () =>
                    addToCart({
                        slug: el.dataset.slug ?? "",
                        variantId: el.dataset.variantId ?? "",
                        name: el.dataset.name ?? "",
                        price: el.dataset.price ?? "",
                        image: el.dataset.image ?? "",
                    }),
                );
            });

        // The count badge toggles the cart open/closed.
        const count = document.getElementById("cart-count");
        count?.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            setOpen(!cartOpen);
        });

        // Clicking the dimming overlay closes the cart.
        document
            .getElementById("cart-overlay")
            ?.addEventListener("click", () => setOpen(false));

        render();
    };

    // Keep the floating panel aligned to the Shop button as the viewport shifts.
    window.addEventListener("resize", positionPanel);
    document.addEventListener("astro:page-load", wire);
</script>
