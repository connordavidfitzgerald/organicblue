---
import { getProducts } from "../lib/products";
import { getArchiveCollections } from "../lib/sanity";
import { storeDomain } from "../lib/shopify";

const products = await getProducts();
const collections = await getArchiveCollections();

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const navItems = [
    { label: "Shop", href: "/shop" },
    { label: "Explorations", href: "/explorations" },
    { label: "Information", href: "/information" },
    { label: "Archive", href: "/archive" },
];

// A nav item is active on its own route and any nested route (e.g. /shop/es-rs).
const isActive = (href: string) =>
    href === "/"
        ? pathname === "/"
        : pathname === href || pathname.startsWith(href + "/");
const isHome = pathname === "/";

// Modular filter row — only rendered on the explorations page.
const showFilters = pathname === "/explorations";
const filters = ["All", "Environment", "Product", "Prototype", "Research"];

// Modular shop row — shown on the shop index and every product detail page.
const showShop = pathname === "/shop" || pathname.startsWith("/shop/");
const currentSlug = pathname.startsWith("/shop/")
    ? pathname.slice("/shop/".length)
    : null;

// Modular archive row — shown on the archive index and every collection page.
// Mirrors the shop row: on the index all labels read as active; on a collection
// page only the current one does.
const showArchive =
    pathname === "/archive" || pathname.startsWith("/archive/");
const currentArchiveSlug = pathname.startsWith("/archive/")
    ? pathname.slice("/archive/".length)
    : null;

// The Shop nav button doubles as the cart toggle. Its count badge is the
// inverse of the button's own colours (button black -> badge grey, and vice
// versa), so we key both off the same active check.
const shopActive = isActive("/shop");
---

<nav
    id="navbar"
    class="grid grid-cols-12 gap-0.5 px-0.5 fixed bottom-0 w-full text-sm text-black z-10 bg-white py-0.5"
>
    {
        showFilters && (
            <>
                <div
                    data-nav-flicker
                    data-nav-key="filters-label"
                    data-nav-state="static"
                    data-flicker-step="0.22"
                    class="cart-dim col-span-3 bg-black text-grey flex items-center w-full px-1 py-1 rounded-xs h-6.5"
                >
                    Filters
                </div>
                <fieldset
                    id="exp-filters"
                    data-nav-flicker
                    data-nav-key="filters"
                    data-nav-state="static"
                    data-flicker-step="0.22"
                    class="cart-dim col-span-9 bg-black text-grey flex items-center justify-between w-full px-2 py-1 rounded-xs h-6.5"
                >
                    {filters.map((label, i) => (
                        <label class="group flex items-center gap-1 cursor-pointer select-none">
                            <input
                                type="radio"
                                name="exp-filter"
                                value={label.toLowerCase()}
                                checked={i === 0}
                                class="appearance-none w-2.5 h-2.5 rounded-full bg-grey outline-none cursor-pointer checked:bg-[radial-gradient(circle,var(--color-black)_0_35%,var(--color-grey)_40%)]"
                            />
                            <span class="transition-opacity group-hover:opacity-60">
                                {label}
                            </span>
                        </label>
                    ))}
                </fieldset>
            </>
        )
    }
    {
        showShop &&
            products.map((p) => (
                <a
                    href={`/shop/${p.slug}`}
                    data-nav-flicker
                    data-nav-key={`shop-${p.slug}`}
                    data-nav-state={
                        currentSlug === null || p.slug === currentSlug
                            ? "on"
                            : "off"
                    }
                    aria-current={p.slug === currentSlug ? "page" : undefined}
                    class:list={[
                        "cart-dim col-span-4 flex items-center justify-between w-full px-1 py-1 rounded-xs h-6.5 transition-colors",
                        currentSlug === null || p.slug === currentSlug
                            ? "bg-black text-grey"
                            : "bg-grey text-black",
                        // No hover on the active product; others invert.
                        p.slug !== currentSlug &&
                            (currentSlug === null
                                ? "hover:bg-grey hover:text-black"
                                : "hover:bg-black hover:text-grey"),
                    ]}
                >
                    <span>{p.name}</span>
                    <span>{p.price}</span>
                </a>
            ))
    }
    {
        showArchive &&
            collections.map((c) => (
                <a
                    href={`/archive/${c.slug}`}
                    data-nav-flicker
                    data-nav-key={`archive-${c.slug}`}
                    data-nav-state={
                        currentArchiveSlug === null ||
                        c.slug === currentArchiveSlug
                            ? "on"
                            : "off"
                    }
                    aria-current={
                        c.slug === currentArchiveSlug ? "page" : undefined
                    }
                    class:list={[
                        "cart-dim col-span-4 flex items-center w-full px-1 py-1 rounded-xs h-6.5 transition-colors",
                        currentArchiveSlug === null ||
                        c.slug === currentArchiveSlug
                            ? "bg-black text-grey"
                            : "bg-grey text-black",
                        // No hover on the active collection; others invert.
                        c.slug !== currentArchiveSlug &&
                            (currentArchiveSlug === null
                                ? "hover:bg-grey hover:text-black"
                                : "hover:bg-black hover:text-grey"),
                    ]}
                >
                    <span>{c.title}</span>
                </a>
            ))
    }
    {
        navItems.map(({ label, href }) =>
            label === "Shop" ? (
                <a
                    id="shop-nav"
                    href={href}
                    data-nav-flicker
                    data-nav-key="nav-shop"
                    data-nav-state={isActive(href) ? "on" : "off"}
                    aria-current={isActive(href) ? "page" : undefined}
                    class:list={[
                        "col-start-1 col-span-3 flex items-center w-full px-1 py-1 rounded-xs h-6.5 transition-colors hover:bg-black hover:text-grey",
                        isActive(href) ? "bg-black text-grey" : "bg-grey",
                    ]}
                >
                    <span id="shop-nav-label">Shop</span>
                    <button
                        id="cart-count"
                        type="button"
                        aria-label="Toggle cart"
                        class:list={[
                            "hidden aspect-square h-4.5 items-center justify-center rounded-xs text-xs leading-none transition-colors",
                            shopActive
                                ? "bg-grey text-black hover:bg-black hover:text-grey"
                                : "bg-black text-grey hover:bg-grey hover:text-black",
                        ]}
                    >
                        0
                    </button>
                </a>
            ) : (
                <a
                    href={href}
                    data-nav-flicker
                    data-nav-key={`nav-${label.toLowerCase()}`}
                    data-nav-state={isActive(href) ? "on" : "off"}
                    aria-current={isActive(href) ? "page" : undefined}
                    class:list={[
                        "cart-dim col-span-3 flex w-full px-1 py-1 rounded-xs h-6.5 transition-colors hover:bg-black hover:text-grey",
                        isActive(href) ? "bg-black text-grey" : "bg-grey",
                    ]}
                >
                    {label}
                </a>
            ),
        )
    }
    <a
        href="/"
        data-nav-flicker
        data-nav-key="nav-home"
        data-nav-state={isHome ? "on" : "off"}
        aria-label="organicblue — home"
        class:list={[
            "cart-dim col-span-12 flex items-center w-full px-1 py-1 rounded-xs h-6.5 transition-colors  hover:bg-black hover:text-grey",
            isHome ? "bg-black text-grey" : "bg-grey text-black",
        ]}
    >
        <svg
            viewBox="0 0 122.75 9"
            role="img"
            aria-label="organicblue logotype"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            class="h-2.5 w-auto"
        >
