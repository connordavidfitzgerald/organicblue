---
// Fills the stage area *above* the navbar and shows one archive image at a time.
// Reads the collection grid's thumbnails (their data-full / data-alt) as the
// image list. Navigate: the vertical middle of the left/right strips, ← / →
// keys, or swipe (wrapping). Close: the corners, the image/backdrop, or Escape.
---

<div
    id="archive-lightbox"
    class="fixed left-0 right-0 top-0 z-40 flex items-center justify-center opacity-0 pointer-events-none"
    style="bottom: var(--nav-h, 3.5rem);"
>
    <div
        id="lightbox-backdrop"
        class="absolute inset-0 bg-white/80 backdrop-blur-sm"
    >
    </div>

    <!-- Prev / next zones cover only the vertical middle of the left/right
         strips; the corners (and centre) fall through to the backdrop = close. -->
    <button
        id="lightbox-prev"
        type="button"
        aria-label="Previous image"
        class="absolute left-0 top-1/4 h-1/2 w-[28%] flex items-center justify-start pl-3 text-black/60 hover:text-black transition-colors cursor-pointer"
    >
        <span class="text-2xl leading-none select-none">‹</span>
    </button>
    <button
        id="lightbox-next"
        type="button"
        aria-label="Next image"
        class="absolute right-0 top-1/4 h-1/2 w-[28%] flex items-center justify-end pr-3 text-black/60 hover:text-black transition-colors cursor-pointer"
    >
        <span class="text-2xl leading-none select-none">›</span>
    </button>

    <img
        id="lightbox-image"
        src=""
        alt=""
        class="relative z-10 h-full max-h-full max-w-full object-contain pointer-events-none px-[28%] py-1"
    />
</div>

<script>
    interface Item {
        full: string;
        alt: string;
    }

    function wireLightbox() {
        const overlay = document.getElementById("archive-lightbox");
        const backdrop = document.getElementById("lightbox-backdrop");
        const image = document.getElementById(
            "lightbox-image",
        ) as HTMLImageElement | null;
        const prevBtn = document.getElementById("lightbox-prev");
        const nextBtn = document.getElementById("lightbox-next");
        const thumbs = Array.from(
            document.querySelectorAll<HTMLButtonElement>(".archive-thumb"),
        );
        if (!overlay || !backdrop || !image || !prevBtn || !nextBtn) return;

        const items: Item[] = thumbs.map((t) => ({
            full: t.dataset.full ?? "",
            alt: t.dataset.alt ?? "",
        }));

        let index = 0;
        let isOpen = false;

        // Keep the overlay's lower edge flush with the top of the navbar.
        const sizeOverlay = () => {
            const nav = document.getElementById("navbar");
            if (nav) overlay.style.bottom = `${nav.offsetHeight}px`;
        };

        const preload = (i: number) => {
            const it = items[i];
            if (it) new Image().src = it.full;
        };

        const show = (i: number) => {
            index = (i + items.length) % items.length;
            const it = items[index];
            if (!it) return;
            image.src = it.full;
            image.alt = it.alt;
            preload(index + 1);
            preload(index - 1 + items.length);
        };

        const open = (i: number) => {
            if (items.length === 0) return;
            sizeOverlay();
            show(i);
            isOpen = true;
            overlay.style.pointerEvents = "auto";
            overlay.style.opacity = "1";
        };

        const close = () => {
            isOpen = false;
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            // Clear src after the fade so we don't flash the old image next open.
            window.setTimeout(() => {
                if (!isOpen) image.src = "";
            }, 300);
        };

        const next = () => show(index + 1);
        const prev = () => show(index - 1);

        // Thumbnails open the lightbox at their index.
        thumbs.forEach((t, i) =>
            t.addEventListener("click", () => open(i)),
        );

        prevBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            prev();
        });
        nextBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            next();
        });
        backdrop.addEventListener("click", close);

        // Keyboard — only while open.
        const onKey = (e: KeyboardEvent) => {
            if (!isOpen) return;
            if (e.key === "ArrowLeft") prev();
            else if (e.key === "ArrowRight") next();
            else if (e.key === "Escape") close();
        };
        document.addEventListener("keydown", onKey);

        // Swipe — horizontal drag past a threshold flips the image and
        // suppresses the click that would otherwise fire on the zone/backdrop.
        let startX = 0;
        let startY = 0;
        let swiped = false;
        overlay.addEventListener("pointerdown", (e) => {
            startX = e.clientX;
            startY = e.clientY;
            swiped = false;
        });
        overlay.addEventListener(
            "click",
            (e) => {
                if (swiped) {
                    e.stopPropagation();
                    swiped = false;
                }
            },
            true, // capture — run before the zone/backdrop click handlers
        );
        overlay.addEventListener("pointerup", (e) => {
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
                swiped = true;
                dx < 0 ? next() : prev();
            }
        });

        window.addEventListener("resize", sizeOverlay);

        // Save cleanup so re-wiring on the next navigation doesn't stack the
        // document-level keydown listener.
        (window as any).__archiveLightboxCleanup?.();
        (window as any).__archiveLightboxCleanup = () => {
            document.removeEventListener("keydown", onKey);
            window.removeEventListener("resize", sizeOverlay);
        };
    }

    document.addEventListener("astro:page-load", wireLightbox);
</script>

<style>
    #archive-lightbox {
        transition: opacity 0.3s ease;
    }
</style>
