---
import { getImage } from "astro:assets";

// Images live in src/assets/images/<category>/*. The folder name
// (environment | product | prototype | research) becomes the sprite's category.
const imageModules = import.meta.glob(
    [
        "../../assets/images/environment/*.{png,jpg,jpeg,webp}",
        "../../assets/images/product/*.{png,jpg,jpeg,webp}",
        "../../assets/images/prototype/*.{png,jpg,jpeg,webp}",
        "../../assets/images/research/*.{png,jpg,jpeg,webp}",
    ],
    { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const entries = Object.entries(imageModules).sort(([a], [b]) =>
    a.localeCompare(b),
);

// Build-time optimization: a small WebP thumbnail powers each of the ~100 sphere
// sprites (fast first paint); a larger WebP is loaded on demand for the overlay.
const images = await Promise.all(
    entries.map(async ([path, img]) => {
        const category =
            path.match(/\/images\/([^/]+)\//)?.[1]?.toLowerCase() ??
            "environment";
        const [thumb, full] = await Promise.all([
            getImage({ src: img, width: 512, format: "webp", quality: 60 }),
            getImage({ src: img, width: 1280, format: "webp", quality: 72 }),
        ]);
        return { thumb: thumb.src, full: full.src, category };
    }),
);
---

<div
    class="absolute inset-0 flex items-center justify-center pointer-events-none"
>
</div>
<canvas
    id="web-canvas"
    data-images={JSON.stringify(images)}
    class="absolute inset-0 w-full h-full"></canvas>

<script>
    import * as THREE from "three";
    import { OrbitControls } from "three/addons/controls/OrbitControls.js";
    import { gsap } from "gsap";

    type SceneImage = { thumb: string; full: string; category: string };

    let disposeScene: (() => void) | null = null;

    function initScene(canvas: HTMLCanvasElement, images: SceneImage[]) {
        gsap.fromTo(
            canvas,
            { opacity: 0 },
            { opacity: 1, duration: 2.5, delay: 0.6, ease: "power3.out" },
        );

        // ── Renderer
        const renderer = new THREE.WebGLRenderer({
            canvas,
            antialias: true,
            alpha: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(canvas.clientWidth, canvas.clientHeight, false);

        // ── Scene & camera
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(
            55,
            canvas.clientWidth / canvas.clientHeight,
            0.1,
            100,
        );
        camera.position.z = 1;

        // ── Controls
        const controls = new OrbitControls(camera, canvas);
        controls.enableDamping = true;
        controls.enablePan = false;
        controls.dampingFactor = 0.05;
        controls.minDistance = 1;
        controls.maxDistance = 7;

        // Track real user interaction (drag start/end) rather than every damped
        // "change" frame — otherwise the coast-to-stop keeps resetting the timer
        // and auto-rotation takes far too long to resume.
        let lastInteractionTime = Date.now();
        let interacting = false;
        controls.addEventListener("start", () => {
            interacting = true;
        });
        controls.addEventListener("end", () => {
            interacting = false;
            lastInteractionTime = Date.now();
        });

        // ── Zoom-to-image state. While zoomed we take over the camera: orbit
        //    controls and auto-rotation are suspended and we look at `lookTarget`
        //    ourselves. `savedCamPos` is where the orbit camera was, to fly back.
        let zoomed = false;
        const lookTarget = new THREE.Vector3(0, 0, 0);
        let savedCamPos = camera.position.clone();

        // ── Web group
        const group = new THREE.Group();
        scene.add(group);

        // ── Fibonacci-sphere layout, parameterised by node count
        const SPHERE_R = 2.5;
        const MIN_R = 1.15;

        // Keep the spacing between neighbouring sprites roughly constant no
        // matter how many are shown: nearest-neighbour distance scales like
        // R / sqrt(count), so R must scale like sqrt(count) to hold it steady.
        // A floor stops very small sets from collapsing onto the camera.
        function radiusFor(count: number): number {
            if (count <= 1) return SPHERE_R;
            const r = SPHERE_R * Math.sqrt(count / images.length);
            return Math.max(r, MIN_R);
        }

        function fibonacciNodes(
            count: number,
            radius = SPHERE_R,
        ): THREE.Vector3[] {
            const out: THREE.Vector3[] = [];
            for (let i = 0; i < count; i++) {
                const phi = Math.acos(1 - (2 * (i + 0.5)) / count);
                const theta = Math.PI * (1 + Math.sqrt(5)) * i;
                out.push(
                    new THREE.Vector3(
                        radius * Math.sin(phi) * Math.cos(theta),
                        radius * Math.sin(phi) * Math.sin(theta),
                        radius * Math.cos(phi),
                    ),
                );
            }
            return out;
        }

        // ── Edges — connect each node to its 3 nearest neighbours
        function computeEdges(pts: THREE.Vector3[]): number[] {
            const seen = new Set<string>();
            const positions: number[] = [];
            for (let i = 0; i < pts.length; i++) {
                const sorted = pts
                    .map((n, j) => ({ j, d: pts[i].distanceTo(n) }))
                    .filter(({ j }) => j !== i)
                    .sort((a, b) => a.d - b.d);
                for (let k = 0; k < Math.min(3, sorted.length); k++) {
                    const { j } = sorted[k];
                    const key = `${Math.min(i, j)}-${Math.max(i, j)}`;
                    if (!seen.has(key)) {
                        seen.add(key);
                        positions.push(
                            pts[i].x,
                            pts[i].y,
                            pts[i].z,
                            pts[j].x,
                            pts[j].y,
                            pts[j].z,
                        );
                    }
                }
            }
            return positions;
        }

        // Full-set layout (the "all" state).
        const allNodes = fibonacciNodes(images.length);
        const fullEdges = computeEdges(allNodes);

        // Images arrive grouped by folder (environment, product, …), so filling
        // the sphere in index order clumps each category into one region. Give
        // every sprite a shuffled sphere slot instead, to interleave categories.
        // Seeded so the arrangement is stable across reloads (no reshuffle jump).
        function makeSlots(n: number): number[] {
            const slots = Array.from({ length: n }, (_, i) => i);
            let seed = (0x9e3779b9 ^ n) >>> 0;
            const rand = () => {
                seed = (seed + 0x6d2b79f5) | 0;
                let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
                t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
                return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
            };
            for (let i = n - 1; i > 0; i--) {
                const j = Math.floor(rand() * (i + 1));
                [slots[i], slots[j]] = [slots[j], slots[i]];
            }
            return slots;
        }
        const slots = makeSlots(images.length);

        const lineGeo = new THREE.BufferGeometry();
        lineGeo.setAttribute(
            "position",
            new THREE.Float32BufferAttribute(fullEdges, 3),
        );
        const lineMat = new THREE.LineBasicMaterial({
            color: 0x000000,
            transparent: true,
            opacity: 0.2,
        });
        group.add(new THREE.LineSegments(lineGeo, lineMat));

        function setEdges(positions: number[]) {
            lineGeo.setAttribute(
                "position",
                new THREE.Float32BufferAttribute(positions, 3),
            );
            lineGeo.computeBoundingSphere();
        }

        // ── Sprites — one per image, auto-billboarded
        const SPRITE_H = 0.55;
        const sprites: THREE.Sprite[] = [];
        const loader = new THREE.TextureLoader();

        // ── Category filtering — `all` is the full sphere; a category re-packs
        //    just its images into a smaller sphere and relinks only those.
        let currentFilter = "all";

        // Transition timings (seconds).
        const T_MOVE = 1.0;
        const T_FADE_OUT = 0.4;
        const T_FADE_IN = 0.6;

        const mat = (s: THREE.Sprite) => s.material as THREE.SpriteMaterial;

        // A sprite that's leaving the current view fades out where it stands —
        // no flight across the sphere — then drops out of rendering.
        function hideSprite(s: THREE.Sprite, animate: boolean) {
            gsap.killTweensOf(s.position);
            if (!animate) {
                mat(s).opacity = 0;
                s.visible = false;
                return;
            }
            gsap.killTweensOf(mat(s));
            gsap.to(mat(s), {
                opacity: 0,
                duration: T_FADE_OUT,
                ease: "power2.in",
                onComplete: () => {
                    s.visible = false;
                },
            });
        }

        // A sprite already on screen glides to its new slot.
        function moveSprite(
            s: THREE.Sprite,
            target: THREE.Vector3,
            animate: boolean,
        ) {
            if (!animate) {
                s.position.copy(target);
                mat(s).opacity = 1;
                return;
            }
            gsap.to(s.position, {
                x: target.x,
                y: target.y,
                z: target.z,
                duration: T_MOVE,
                ease: "power2.inOut",
            });
            gsap.killTweensOf(mat(s));
            gsap.to(mat(s), {
                opacity: 1,
                duration: T_FADE_IN,
                ease: "power2.out",
            });
        }

        // A sprite entering the view materialises directly at its target slot
        // and fades + scales in — so it never streaks in from the far side.
        function revealSprite(
            s: THREE.Sprite,
            target: THREE.Vector3,
            animate: boolean,
        ) {
            gsap.killTweensOf(s.position);
            gsap.killTweensOf(mat(s));
            gsap.killTweensOf(s.scale);
            s.position.copy(target);
            s.visible = true;
            const base = s.userData.baseScale as THREE.Vector3;
            if (!animate) {
                mat(s).opacity = 1;
                s.scale.copy(base);
                return;
            }
            mat(s).opacity = 0;
            s.scale.set(base.x * 0.7, base.y * 0.7, 1);
            gsap.to(mat(s), {
                opacity: 1,
                duration: T_FADE_IN,
                ease: "power2.out",
            });
            gsap.to(s.scale, {
                x: base.x,
                y: base.y,
                duration: T_FADE_IN,
                ease: "back.out(1.4)",
            });
        }

        function applyEdges(positions: number[], animate: boolean) {
            if (!animate) {
                setEdges(positions);
                lineMat.opacity = 0.2;
                return;
            }
            // Fade the web out, swap links once the sprites have settled, fade in.
            gsap.to(lineMat, { opacity: 0, duration: 0.3, ease: "power2.out" });
            gsap.delayedCall(1.0, () => {
                setEdges(positions);
                gsap.to(lineMat, {
                    opacity: 0.2,
                    duration: 0.6,
                    ease: "power2.out",
                });
            });
        }

        function relayout(animate: boolean) {
            // Resolve which sprites are shown and where each one lands.
            const targets = new Map<THREE.Sprite, THREE.Vector3>();
            let edges: number[];
            if (currentFilter === "all") {
                sprites.forEach((s) =>
                    targets.set(s, allNodes[s.userData.slot]),
                );
                edges = fullEdges;
            } else {
                const shown = sprites
                    .filter((s) => s.userData.category === currentFilter)
                    .sort((a, b) => a.userData.index - b.userData.index);
                const nodes = fibonacciNodes(
                    shown.length,
                    radiusFor(shown.length),
                );
                shown.forEach((s, k) => targets.set(s, nodes[k]));
                edges = computeEdges(nodes);
            }

            sprites.forEach((s) => {
                const target = targets.get(s);
                if (!target) {
                    hideSprite(s, animate);
                    return;
                }
                // Sprites that were off-screen appear in place; visible ones glide.
                const hidden = !s.visible || mat(s).opacity < 0.05;
                if (hidden) revealSprite(s, target, animate);
                else moveSprite(s, target, animate);
            });

            applyEdges(edges, animate);
        }

        images.forEach(({ thumb, full, category }, i) => {
            loader.load(thumb, (texture) => {
                const aspect = texture.image.width / texture.image.height;
                const sprite = new THREE.Sprite(
                    new THREE.SpriteMaterial({
                        map: texture,
                        transparent: true,
                    }),
                );
                sprite.position.copy(allNodes[slots[i]]);
                sprite.scale.set(SPRITE_H * aspect, SPRITE_H, 1);
                sprite.userData = {
                    url: full,
                    index: i,
                    slot: slots[i],
                    category,
                    baseScale: sprite.scale.clone(),
                };
                sprite.visible =
                    currentFilter === "all" || category === currentFilter;
                group.add(sprite);
                sprites.push(sprite);
                // If a category is active while textures still stream in, fold
                // newly-loaded matches into the packed layout.
                if (currentFilter !== "all" && category === currentFilter) {
                    relayout(false);
                }
            });
        });

        const onFilter = (e: Event) => {
            currentFilter = (e as CustomEvent<{ category: string }>).detail
                .category;
            relayout(true);
        };
        window.addEventListener("filter:change", onFilter);

        // ── Zoom the camera in on a clicked sprite, framing it centre-screen.
        //    Sprites are billboards on the sphere, so we sit the camera on the
        //    line from the centre out through the sprite and look straight at it.
        function zoomToSprite(sprite: THREE.Sprite) {
            if (zoomed) return;
            zoomed = true;
            controls.enabled = false;
            lastInteractionTime = Date.now();
            savedCamPos = camera.position.clone();

            const worldP = new THREE.Vector3();
            sprite.getWorldPosition(worldP);
            const dir = worldP.clone().normalize();

            // Distance that fits the whole sprite in view — limited by whichever
            // of width/height is tighter against the frame — plus a little margin.
            const vFov = (camera.fov * Math.PI) / 180;
            const hFov = 2 * Math.atan(Math.tan(vFov / 2) * camera.aspect);
            const distH = sprite.scale.y / 2 / Math.tan(vFov / 2);
            const distW = sprite.scale.x / 2 / Math.tan(hFov / 2);
            const dist = Math.max(distH, distW) * 1.3;

            const camGoal = worldP.clone().sub(dir.multiplyScalar(dist));

            gsap.to(camera.position, {
                x: camGoal.x,
                y: camGoal.y,
                z: camGoal.z,
                duration: 1.1,
                ease: "power3.inOut",
            });
            gsap.to(lookTarget, {
                x: worldP.x,
                y: worldP.y,
                z: worldP.z,
                duration: 1.1,
                ease: "power3.inOut",
            });
        }

        // Fly back to the orbit position and hand control back to OrbitControls.
        function zoomOut() {
            if (!zoomed) return;
            lastInteractionTime = Date.now();
            gsap.to(camera.position, {
                x: savedCamPos.x,
                y: savedCamPos.y,
                z: savedCamPos.z,
                duration: 1.0,
                ease: "power3.inOut",
            });
            gsap.to(lookTarget, {
                x: 0,
                y: 0,
                z: 0,
                duration: 1.0,
                ease: "power3.inOut",
                onComplete: () => {
                    zoomed = false;
                    controls.enabled = true;
                },
            });
        }

        // ── Click detection
        const raycaster = new THREE.Raycaster();
        const pointer = new THREE.Vector2();
        let pointerDown = { x: 0, y: 0 };

        const onPointerDown = (e: PointerEvent) => {
            pointerDown = { x: e.clientX, y: e.clientY };
        };
        const onPointerUp = (e: PointerEvent) => {
            if (
                Math.hypot(
                    e.clientX - pointerDown.x,
                    e.clientY - pointerDown.y,
                ) > 5
            )
                return;
            // While zoomed in, any click flies the camera back out.
            if (zoomed) {
                zoomOut();
                return;
            }
            const rect = canvas.getBoundingClientRect();
            pointer.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
            pointer.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
            raycaster.setFromCamera(pointer, camera);
            const hits = raycaster.intersectObjects(
                sprites.filter((s) => s.visible),
            );
            if (hits.length > 0) {
                zoomToSprite(hits[0].object as THREE.Sprite);
            }
        };

        canvas.addEventListener("pointerdown", onPointerDown);
        canvas.addEventListener("pointerup", onPointerUp);

        // ── Resize
        const ro = new ResizeObserver(() => {
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h, false);
        });
        ro.observe(canvas);

        // ── Render loop — pauseable so we can free the frame budget during transitions
        let rafId = 0;
        let running = false;

        function startLoop() {
            if (running) return;
            running = true;
            function tick() {
                if (!running) return;
                rafId = requestAnimationFrame(tick);
                if (zoomed) {
                    // Camera is being flown by GSAP; just keep it aimed.
                    camera.lookAt(lookTarget);
                } else {
                    controls.update();
                    if (!interacting && Date.now() - lastInteractionTime > 1200)
                        group.rotation.y += 0.0015;
                }
                renderer.render(scene, camera);
            }
            tick();
        }

        function stopLoop() {
            running = false;
            cancelAnimationFrame(rafId);
        }

        // Pause automatically when the canvas is off-screen (other sections / other pages)
        const io = new IntersectionObserver(
            ([entry]) => {
                entry.isIntersecting ? startLoop() : stopLoop();
            },
            { threshold: 0.1 },
        );
        io.observe(canvas);
        startLoop();

        // ── Return teardown
        return () => {
            stopLoop();
            io.disconnect();
            ro.disconnect();
            window.removeEventListener("filter:change", onFilter);
            canvas.removeEventListener("pointerdown", onPointerDown);
            canvas.removeEventListener("pointerup", onPointerUp);
            // Kill any in-flight relayout tweens/delayed calls so they can't fire
            // against the disposed scene after navigation.
            gsap.killTweensOf(lineMat);
            gsap.killTweensOf(camera.position);
            gsap.killTweensOf(lookTarget);
            sprites.forEach((s) => {
                gsap.killTweensOf(s.position);
                gsap.killTweensOf(s.scale);
                gsap.killTweensOf(s.material);
            });
            controls.dispose();
            renderer.dispose();
        };
    }

    function tryInit() {
        disposeScene?.();
        disposeScene = null;

        const canvas = document.getElementById(
            "web-canvas",
        ) as HTMLCanvasElement | null;
        if (!canvas) return;

        const images: SceneImage[] = JSON.parse(canvas.dataset.images!);

        function attempt() {
            if (!canvas!.isConnected) return;
            if (canvas!.clientWidth === 0 || canvas!.clientHeight === 0) {
                requestAnimationFrame(attempt);
                return;
            }
            disposeScene = initScene(canvas!, images);
        }
        requestAnimationFrame(attempt);
    }

    // Stop the loop the moment navigation begins — frees the frame budget for GSAP
    document.addEventListener("astro:before-swap", () => {
        disposeScene?.();
        disposeScene = null;
    });

    document.addEventListener("astro:page-load", tryInit);
</script>
