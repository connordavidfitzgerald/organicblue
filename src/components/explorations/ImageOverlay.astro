---

<div
    id="img-overlay"
    class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none"
>
    <div
        id="overlay-backdrop"
        class="absolute inset-0 bg-white/70 backdrop-blur-sm"
    >
    </div>
    <div
        id="overlay-card"
        class="relative z-10 flex flex-col items-start gap-0 p-8 max-w-2xl w-full"
    >
        <img
            id="overlay-image"
            src=""
            alt=""
            class="max-h-[70vh] max-w-full object-contain"
        />
        <p
            id="overlay-label"
            class="text-white bg-black/40 leading-[120%] pl-1 py-0.5 w-[33%] text-xs tracking-normal"
        >
        </p>
    </div>
</div>

<script>
    import { gsap } from "gsap";

    // Persistent — lives on window so it survives navigation.
    // Uses lazy DOM lookup each time so it always finds the current elements.
    window.addEventListener("overlay:open", (e) => {
        const overlay = document.getElementById("img-overlay");
        const card = document.getElementById("overlay-card");
        const image = document.getElementById(
            "overlay-image",
        ) as HTMLImageElement | null;
        const label = document.getElementById("overlay-label");
        if (!overlay || !card || !image || !label) return;

        const { url, index } = (e as CustomEvent).detail;
        image.src = url;
        label.textContent = `REF 00${index + 1}`;
        overlay.style.pointerEvents = "auto";
        gsap.to(overlay, { opacity: 1, duration: 0.35, ease: "power2.out" });
        gsap.to(card, { scale: 1, duration: 0.35, ease: "power2.out" });
    });

    // Re-attach close/backdrop listeners to the fresh elements on every navigation.
    document.addEventListener("astro:page-load", () => {
        const overlay = document.getElementById("img-overlay");
        const card = document.getElementById("overlay-card");
        const closeBtn = document.getElementById("overlay-close");
        const backdrop = document.getElementById("overlay-backdrop");
        if (!overlay || !card) return;

        gsap.set(card, { scale: 0.95 });

        function closeOverlay() {
            gsap.to(overlay!, {
                opacity: 0,
                duration: 0.25,
                ease: "power2.in",
                onComplete: () => {
                    overlay!.style.pointerEvents = "none";
                    (
                        document.getElementById(
                            "overlay-image",
                        ) as HTMLImageElement
                    ).src = "";
                    gsap.set(card, { scale: 0.95 });
                },
            });
        }

        closeBtn?.addEventListener("click", closeOverlay);
        backdrop?.addEventListener("click", (e) => {
            if (e.target === backdrop) closeOverlay();
        });
    });
</script>
