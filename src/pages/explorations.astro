---
import Layout from "../layouts/Layout.astro";
import WebScene from "../components/explorations/WebScene.astro";
---

<Layout title="Organic Blue">
    <div
        id="exp-stage"
        class="fixed left-0 right-0 top-0 bg-grey"
        style="bottom: var(--nav-h, 5rem);"
    >
        <WebScene />
    </div>
</Layout>

<script>
    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("exp-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
