---
import Layout from "../layouts/Layout.astro";
import WebScene from "../components/explorations/WebScene.astro";
import ImageOverlay from "../components/explorations/ImageOverlay.astro";
import ProductViewer from "../components/explorations/ProductViewer.astro";

const productImgs = import.meta.glob("../assets/images/ES*.png", {
    eager: true,
    query: "?url",
    import: "default",
}) as Record<string, string>;

const onBodyImgs = import.meta.glob("../assets/images/on-body/*.png", {
    eager: true,
    query: "?url",
    import: "default",
}) as Record<string, string>;

function img(name: string, view: string): string {
    const target = `${name} ${view}.png`;
    const entry = Object.entries(productImgs).find(([path]) =>
        path.endsWith(target),
    );
    return entry?.[1] ?? "";
}

function onBodyFor(prefix: string): string[] {
    return Object.entries(onBodyImgs)
        .filter(([path]) => path.includes(`/on-body/${prefix}-`))
        .sort(([a], [b]) => a.localeCompare(b))
        .map(([, url]) => url);
}

const products = [
    {
        name: "ES prototype 1",
        front: img("ES1", "Front"),
        side: img("ES1", "Side"),
        back: img("ES1", "Back"),
        onBodyImages: onBodyFor("ES1"),
        description: `Low-light. Summer nights spent biking with friends. The particular freedom of moving through warm evenings with nowhere urgent to be. We wondered: can we capture that feeling in an object?\n\nWe started the process by studying how the body moves, where a pack makes contact, where friction and fatigue accumulate. From that understanding, we made a set of rules: no bounce, no shoulder dig, under 500g, and weather resistant. The intention was a pack that disappears into your movement. Something you look forward to bringing rather than something you tolerate.`,
    },
    {
        name: "ES prototype 2",
        front: img("ES2", "Front"),
        side: img("ES2", "Side"),
        back: img("ES2", "Back"),
        onBodyImages: onBodyFor("ES2"),
        description: `From the foundation we built, we wanted to push ahead further. We merged the front contrast panels into a single fluid form, allowing the bag to read as one continuous shape rather than an assembly of parts. Organic, considered, resolved.\n
        Two things defined this prototype. Size came first: volume expanded to accommodate a wider range of gear. Then the back panel, sculpted to follow the natural geometry of the human spine, keeping only what makes contact and removing everything that doesn't. That same principle of reduction led to the prototype's most considered detail: a retractable hip belt. Essential when you're moving hard, invisible when you're not. Tucked into the back panel, it leaves a clean silhouette behind.`,
    },
    {
        name: "ES.RS final render",
        front: img("ESRS", "Front"),
        side: img("ESRS", "Side"),
        back: img("ESRS", "Back"),
        onBodyImages: onBodyFor("ESRS"),
        description: `The hip belt raised a new question. What would it look like to develop two distinct versions of the same architecture, sharing a structure but tuned for entirely different lives? The answer came from Group B rally, where manufacturers built road-legal homologation versions of their competition cars. Two products, one DNA, two expressions.\n
        ES.RS was built around a single idea: the minimum amount of equipment enabling maximum flow. Designed for fast-packing, covering long distances on foot in short windows of time, carrying only what is essential. Every decision followed from that intent.\n
        The load sits in the thoracic zone, the upper back between the shoulder blades and along the spine. Carried here, weight is supported by the body's core. The hips stay free, fatigue is reduced, and bounce is naturally minimised. The straps are wider than conventional, distributing load evenly across the shoulders while doubling as a carry system for two 500ml flasks. Hydration stays accessible. The pack stays on`,
    },
    {
        name: "ES.ST final render",
        front: img("ESST", "Front"),
        side: img("ESST", "Side"),
        back: img("ESST", "Back"),
        onBodyImages: onBodyFor("ESST"),
        description: `Where the ES.RS was built for the trail, the ES.ST is its urban counterpart. The same chassis, the same vest straps, the same thoracic placement. But the surface language is entirely its own, drawn from two references that seem unlikely until they don't.\n
        Moths are ancient creatures. Their wing geometry is precise, almost architectural, shaped over millennia to scatter the echolocation signals of hunting bats. The ES.ST borrows that logic of disruption. Rather than reading as a clean, contained silhouette, the pack introduces forms that interrupt expectation and open up new ways of understanding its shape.\n
        Manta rays move differently. Built to glide through water across enormous distances with minimal effort, their design is one of nature's most elegant solutions to continuous movement. The ES.ST carries that same intention. Fitted to the thoracic zone, it moves with the body rather than against it, built for people who are always going somewhere.`,
    },
];
---

<Layout title="explorations — organicblue">
    <div
        id="exp-scroller"
        class="flex h-screen overflow-x-scroll overflow-y-hidden"
        style="scroll-snap-type: x mandatory;"
    >
        <!-- Section 1: Three.js web -->
        <section
            class="relative flex-shrink-0 w-screen h-screen bg-white"
            style="scroll-snap-align: start;"
        >
            <WebScene />
        </section>

        <!-- Sections 2–5: Product viewers -->
        {
            products.map((p) => (
                <section
                    class="relative flex-shrink-0 w-screen h-screen bg-white overflow-hidden"
                    style="scroll-snap-align: start;"
                >
                    <ProductViewer
                        name={p.name}
                        front={p.front}
                        side={p.side}
                        back={p.back}
                        onBodyImages={p.onBodyImages}
                        description={p.description}
                    />
                </section>
            ))
        }

        <!-- Section 6: Dual cart viewer (ES.ST + ES.RS side by side) -->
        <section
            class="relative flex-shrink-0 w-screen h-screen bg-white overflow-hidden"
            style="scroll-snap-align: start;"
        >
            <div class="dual-viewers absolute inset-0 flex justify-center">
                <div class="relative w-[38%] h-full">
                    <ProductViewer
                        name={products[2].name}
                        front={products[2].front}
                        side={products[2].side}
                        back={products[2].back}
                        cartMode={true}
                    />
                </div>
                <div class="relative w-[38%] h-full">
                    <ProductViewer
                        name={products[3].name}
                        front={products[3].front}
                        side={products[3].side}
                        back={products[3].back}
                        cartMode={true}
                    />
                </div>
            </div>
        </section>
    </div>

    <!-- Pure click navigation zones -->
    <div
        id="nav-prev"
        class="fixed left-0 top-0 w-40 h-screen z-40 cursor-pointer"
    >
    </div>
    <div
        id="nav-next"
        class="fixed right-0 top-0 w-40 h-screen z-40 cursor-pointer"
    >
    </div>

    <!-- Page counter -->
    <div
        id="page-counter"
        class="fixed bottom-10 left-0 right-0 flex justify-center gap-4 z-40"
    >
        {
            [0, 1, 2, 3, 4, 5].map((i) => (
                <button
                    class="page-dot text-[10px] tracking-normal px-0.5 py-0.5 transition-colors cursor-pointer hover:!bg-black/50 hover:!text-white"
                    data-idx={i}
                >
                    {String(i + 1).padStart(2, "0")}
                </button>
            ))
        }
    </div>

    <ImageOverlay />

    <!-- Custom cursor label -->
    <div
        id="exp-cursor"
        class="fixed top-0 left-0 pointer-events-none z-50 hidden font-sans text-sm mix-blend-difference"
        style="transform: translate(-50%, -50%);"
    >
        <span id="exp-cursor-text" class="text-white/30">previous</span>
    </div>
</Layout>

<script>
    import { gsap } from "gsap";

    function scrambleText(el: HTMLElement, duration = 0.75) {
        const final = el.textContent ?? "";
        const chars = "00000000000";
        const frames = Math.round(duration * 60);
        let frame = 0;
        function tick() {
            frame++;
            const progress = frame / frames;
            let result = "";
            for (let i = 0; i < final.length; i++) {
                if (
                    !/[a-zA-Z0-9]/.test(final[i]) ||
                    i / final.length < progress
                ) {
                    result += final[i];
                } else {
                    result += chars[Math.floor(Math.random() * chars.length)];
                }
            }
            el.textContent = result;
            if (frame < frames) requestAnimationFrame(tick);
            else el.textContent = final;
        }
        requestAnimationFrame(tick);
    }

    document.addEventListener("astro:page-load", () => {
        const scroller = document.getElementById("exp-scroller");
        if (!scroller) return;

        const sections = Array.from(scroller.querySelectorAll("section"));
        const dots = Array.from(
            document.querySelectorAll<HTMLElement>(".page-dot"),
        );
        let currentIdx = 0;

        function updateCounter(idx: number) {
            dots.forEach((dot, i) => {
                dot.style.color =
                    i === idx ? "rgba(0,0,0,0.5)" : "rgba(0,0,0,0.3)";
            });
        }

        function getContent(section: Element): Element | null {
            return section.querySelector(
                "#web-canvas, .dual-viewers, .product-viewer",
            );
        }

        function navigateTo(idx: number) {
            const next = Math.max(0, Math.min(idx, sections.length - 1));
            if (next === currentIdx) return;
            currentIdx = next;

            scroller!.scrollTo({
                left: next * window.innerWidth,
                behavior: "instant",
            });

            updateCounter(next);

            const content = getContent(sections[next]);
            const labelEls = Array.from(
                sections[next].querySelectorAll<HTMLElement>(
                    ".product-name, .product-info-toggle, .product-cart-btn",
                ),
            );
            labelEls.forEach((el) => (el.style.opacity = "0"));

            if (content) {
                gsap.fromTo(
                    content,
                    { opacity: 0, filter: "blur(16px)" },
                    {
                        opacity: 1,
                        filter: "blur(0px)",
                        duration: 1,
                        delay: 0.1,
                        ease: "power3.inut",
                        onStart: () => {
                            labelEls.forEach((el) => {
                                el.style.opacity = "1";
                                scrambleText(el);
                            });
                        },
                    },
                );
            }

            const onBody =
                sections[next].querySelector<HTMLElement>(".on-body-scroll");
            if (onBody) {
                gsap.fromTo(
                    onBody,
                    { width: "50%" },
                    {
                        width: "33.3%",
                        duration: 1,
                        delay: 0.1,
                        ease: "power3.inOut",
                    },
                );
            }
        }

        updateCounter(0);

        dots.forEach((dot) => {
            dot.addEventListener("click", () =>
                navigateTo(Number(dot.dataset.idx)),
            );
        });

        document
            .getElementById("nav-prev")
            ?.addEventListener("click", () => navigateTo(currentIdx - 1));
        document
            .getElementById("nav-next")
            ?.addEventListener("click", () => navigateTo(currentIdx + 1));

        // Custom cursor labels on click zones
        const expCursor = document.getElementById(
            "exp-cursor",
        ) as HTMLElement | null;
        const expCursorText = document.getElementById(
            "exp-cursor-text",
        ) as HTMLElement | null;

        function attachCursor(selector: string, label: string) {
            document.querySelectorAll<HTMLElement>(selector).forEach((el) => {
                el.style.cursor = "none";
                el.addEventListener("mouseenter", () => {
                    if (expCursorText) expCursorText.textContent = label;
                    expCursor?.classList.remove("hidden");
                });
                el.addEventListener("mouseleave", () => {
                    expCursor?.classList.add("hidden");
                });
                el.addEventListener("mousemove", (e) => {
                    if (!expCursor) return;
                    expCursor.style.left = e.clientX + "px";
                    expCursor.style.top = e.clientY + "px";
                });
            });
        }

        attachCursor("#nav-prev", "‹");
        attachCursor("#nav-next", "›");
        attachCursor(".product-prev", "‹");
        attachCursor(".product-next", "›");
    });
</script>
