---
import Layout from "../layouts/Layout.astro";
import { getArchiveCollections, urlFor } from "../lib/sanity";

const collections = await getArchiveCollections();
---

<Layout title="Archive — Organic Blue">
    <!-- Three collection columns, mirroring the shop index. -->
    <div
        id="archive-stage"
        class="fixed left-0 right-0 top-0 grid grid-cols-3 grid-rows-1 gap-0.5 px-0.5 pt-0.5 text-xs text-black"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        {
            collections.map((c) => (
                <a
                    href={`/archive/${c.slug}`}
                    class="h-full w-full rounded-xs bg-grey overflow-hidden flex items-center justify-center transition-opacity hover:opacity-80"
                >
                    {c.coverImage ? (
                        <img
                            src={urlFor(c.coverImage)
                                .width(1200)
                                .height(1500)
                                .fit("crop")
                                .auto("format")
                                .url()}
                            alt={c.title}
                            class="h-full w-full object-cover"
                        />
                    ) : (
                        <span>{c.title}</span>
                    )}
                </a>
            ))
        }
    </div>
</Layout>

<script>
    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("archive-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
