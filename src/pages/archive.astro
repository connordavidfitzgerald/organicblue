---
import Layout from "../layouts/Layout.astro";
import { getArchiveCollections, urlFor } from "../lib/sanity";

const collections = await getArchiveCollections();
---

<Layout title="Archive — Organic Blue">
    <!-- Three collection columns, mirroring the shop index. -->
    <div
        id="archive-stage"
        data-hover-dim
        class="fixed left-0 right-0 top-0 grid grid-cols-3 grid-rows-1 gap-0.5 px-0.5 pt-0.5 text-xs text-black"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        {
            collections.map((c) => {
                // Cover at rest, then cycle through preview images on hover.
                const sources = [
                    ...(c.coverImage ? [c.coverImage] : []),
                    ...(c.previewImages ?? []),
                ];
                const urls = [
                    ...new Set(
                        sources.map((img) =>
                            urlFor(img)
                                .width(1200)
                                .height(1500)
                                .fit("crop")
                                .auto("format")
                                .url(),
                        ),
                    ),
                ];
                return (
                    <a
                        href={`/archive/${c.slug}`}
                        data-flicker
                        data-flicker-step="0.1"
                        data-flicker-ease="power2.out"
                        class="h-full w-full rounded-xs bg-grey overflow-hidden flex items-center justify-center"
                    >
                        {urls[0] ? (
                            <img
                                src={urls[0]}
                                alt={c.title}
                                data-hover-gallery={JSON.stringify(urls)}
                                class="h-full w-full object-cover"
                            />
                        ) : (
                            <span>{c.title}</span>
                        )}
                    </a>
                );
            })
        }
    </div>
</Layout>

<script>
    import "../scripts/hoverGallery";

    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("archive-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
