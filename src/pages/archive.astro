---
import Layout from "../layouts/Layout.astro";
import { Image, getImage } from "astro:assets";

// Every image in src/assets/images/Archive powers the grid. Thumbnails are
// rendered with <Image> (build-time optimized); a larger WebP drives the
// scrollable left-hand preview.
const modules = import.meta.glob(
    "../assets/images/Archive/*.{png,jpg,jpeg,webp,PNG,JPG,JPEG}",
    { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const entries = Object.entries(modules).sort(([a], [b]) => a.localeCompare(b));

const images = await Promise.all(
    entries.map(async ([path, img], i) => {
        const full = await getImage({
            src: img,
            width: 1600,
            format: "webp",
            quality: 78,
        });
        return {
            meta: img,
            full: full.src,
            alt: path.split("/").pop() ?? `archive-${i}`,
        };
    }),
);
---

<Layout title="Archive — Organic Blue">
    <div
        id="archive-stage"
        class="fixed left-0 right-0 top-0 flex flex-row gap-0.5 px-0.5 pt-0.5 text-xs text-grey"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        <!-- Left column: scroll through all full-size images -->
        <div
            id="archive-preview"
            class="archive-preview w-full h-full overflow-y-auto snap-y snap-mandatory rounded-xs bg-black"
        >
            {
                images.map((img, i) => (
                    <div
                        class="archive-slide h-full w-full snap-start snap-always"
                        data-index={i}
                    >
                        <img
                            src={img.full}
                            alt={img.alt}
                            loading={i === 0 ? "eager" : "lazy"}
                            class="w-full h-full object-cover"
                        />
                    </div>
                ))
            }
        </div>

        <!-- Right column: 12-col grid of 4:5 thumbnails -->
        <div class="archive-thumbs w-full h-full overflow-y-auto">
            <div class="grid grid-cols-12 gap-0.5">
                {
                    images.map((img, i) => (
                        <button
                            type="button"
                            class="archive-thumb block w-full aspect-[4/5] overflow-hidden rounded-xs bg-black transition-[filter] duration-200"
                            data-index={i}
                            aria-label={`Preview ${img.alt}`}
                        >
                            <Image
                                src={img.meta}
                                alt={img.alt}
                                width={320}
                                format="webp"
                                quality={60}
                                loading="lazy"
                                class="w-full h-full object-cover"
                            />
                        </button>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Hide the scrollbars on both columns */
    .archive-thumbs,
    .archive-preview {
        scrollbar-width: none;
    }
    .archive-thumbs::-webkit-scrollbar,
    .archive-preview::-webkit-scrollbar {
        display: none;
    }
    /* The active thumbnail — and any hovered one — desaturates to B&W */
    .archive-thumb:hover,
    .archive-thumb[data-selected] {
        filter: grayscale(1);
    }
</style>

<script>
    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("archive-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    function wireArchive() {
        sizeStage();

        const preview = document.getElementById("archive-preview");
        const slides = Array.from(
            document.querySelectorAll<HTMLElement>(".archive-slide"),
        );
        const thumbs = Array.from(
            document.querySelectorAll<HTMLButtonElement>(".archive-thumb"),
        );
        if (!preview || slides.length === 0 || thumbs.length === 0) return;

        const select = (index: number) => {
            thumbs.forEach((b, k) =>
                k === index
                    ? b.setAttribute("data-selected", "")
                    : b.removeAttribute("data-selected"),
            );
        };

        // Click a thumbnail -> scroll the preview to that image.
        thumbs.forEach((btn, i) => {
            btn.addEventListener("click", () => {
                slides[i]?.scrollIntoView({
                    behavior: "smooth",
                    block: "start",
                });
                select(i);
            });
        });

        // Scrolling the preview keeps the matching thumbnail selected.
        (window as any).__archiveIO?.disconnect();
        const io = new IntersectionObserver(
            (obs) => {
                obs.forEach((e) => {
                    if (e.isIntersecting)
                        select(Number((e.target as HTMLElement).dataset.index));
                });
            },
            { root: preview, threshold: 0.6 },
        );
        slides.forEach((s) => io.observe(s));
        (window as any).__archiveIO = io;
    }

    document.addEventListener("astro:page-load", wireArchive);
    window.addEventListener("resize", sizeStage);
</script>
