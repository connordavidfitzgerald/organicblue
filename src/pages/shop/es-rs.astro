---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getProduct } from "../../lib/products";
import SpecPanel from "../../components/shop/SpecPanel.astro";

const product = await getProduct("es-rs");

// Local ES.RS gallery — used as a fallback when Shopify has no product images.
const esrsModules = import.meta.glob(
    "../../assets/images/esrs_assets/*.{png,jpg,jpeg,webp}",
    { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const esrsImages = Object.entries(esrsModules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, img]) => img);

const shopifyImages = product?.images ?? [];

// Thumbnail stored with the cart line — Shopify image if present, else the
// first local gallery image.
const cartImage = shopifyImages[0]?.url ?? esrsImages[0]?.src ?? "";
---

<Layout title="ES.RS — Organic Blue">
    <div
        id="shop-stage"
        class="fixed left-0 right-0 top-0 flex flex-row gap-0.5 px-0.5 pt-0.5 text-xs text-grey"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        <!-- Column 1: product info -->
        <div class="flex w-full h-full flex-col gap-0.5">
            <div
                class="flex w-full px-1 py-1 rounded-xs grow flex-col justify-center items-center bg-black"
            >
                <div class="text-center">
                    <p>{product?.detailTitle}</p>
                    {
                        product?.description && (
                            <div
                                class="prose-none"
                                set:html={product.description}
                            />
                        )
                    }
                </div>
            </div>
            {
                product && (
                    <button
                        type="button"
                        data-add-to-cart
                        data-slug={product.slug}
                        data-name={product.name}
                        data-price={product.price}
                        data-image={cartImage}
                        class="flex w-full px-1 py-1 rounded-xs h-6 flex-row justify-between bg-black transition-opacity hover:opacity-80"
                    >
                        <span>Add to cart</span>
                        <span>{product.price}</span>
                    </button>
                )
            }
            {
                product && (
                    <SpecPanel
                        product={product}
                        columns={[
                            [
                                { label: "Volume", key: "volume" },
                                { label: "Tuned for", key: "tuned_for" },
                            ],
                            [
                                { label: "Production", key: "production" },
                                { label: "Weight", key: "weight" },
                            ],
                            [{ label: "Materials", key: "materials" }],
                        ]}
                    />
                )
            }
        </div>

        <!-- Column 2: gallery — Shopify images if present, else local ES.RS set -->
        <div
            class="shop-gallery h-full w-full overflow-y-auto snap-y snap-mandatory rounded-xs bg-black"
        >
            {
                shopifyImages.length > 0
                    ? shopifyImages.map((img) => (
                          <div class="h-full w-full snap-start snap-always">
                              <img
                                  src={img.url}
                                  alt={img.alt}
                                  class="w-full h-full object-cover rounded-xs"
                              />
                          </div>
                      ))
                    : esrsImages.map((img, i) => (
                          <div class="h-full w-full snap-start snap-always">
                              <Image
                                  src={img}
                                  alt={`ES.RS view ${i + 1}`}
                                  class="w-full h-full object-cover rounded-xs"
                              />
                          </div>
                      ))
            }
        </div>
    </div>
</Layout>

<style>
    /* Hide the scrollbar on the gallery column */
    .shop-gallery {
        scrollbar-width: none;
    }
    .shop-gallery::-webkit-scrollbar {
        display: none;
    }
</style>

<script>
    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("shop-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
