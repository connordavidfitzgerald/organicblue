---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/products";

const products = await getProducts();

// Hover cycle uses a hand-picked subset of each product's photos rather than
// every image. Numbers are 1-based, matching the photo order in Shopify. The
// first pick doubles as the at-rest cover. Products not listed here fall back
// to cycling through all their images.
const HOVER_PICKS: Record<string, number[]> = {
    "es-rs": [1, 2, 6],
    "es-cap": [1, 2, 4],
    "es-st": [1, 2, 5],
};
---

<Layout title="Organic Blue">
    <!-- Three product columns, aligned with the navbar shop row above the nav. -->
    <div
        id="shop-stage"
        data-hover-dim
        class="fixed left-0 right-0 top-0 grid grid-cols-3 grid-rows-1 gap-0.5 px-0.5 pt-0.5 text-xs text-black"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        {
            products.map((p) => {
                // Cycle through the hand-picked photos on hover (falling back to
                // all images), keeping distinct URLs only. Out-of-range picks
                // (e.g. fallback mode with no images) are dropped.
                const picks = HOVER_PICKS[p.slug];
                const selected = picks
                    ? picks.map((n) => p.images[n - 1]).filter(Boolean)
                    : p.images;
                const urls = [...new Set(selected.map((img) => img.url))];
                return (
                    <a
                        href={`/shop/${p.slug}`}
                        data-fade-in
                        data-fade-in-step="0.13"
                        data-fade-in-duration="0.7"
                        data-fade-in-ease="power3.out"
                        class="h-full w-full rounded-xs bg-[#3f3f3f] overflow-hidden flex items-center justify-center"
                    >
                        {urls[0] ? (
                            <img
                                src={urls[0]}
                                alt={p.images[0]?.alt ?? p.name}
                                data-hover-gallery={JSON.stringify(urls)}
                                class="h-full w-full object-cover"
                            />
                        ) : (
                            <span>{p.name}</span>
                        )}
                    </a>
                );
            })
        }
    </div>
</Layout>

<script>
    import "../scripts/hoverGallery";
    import "../scripts/fadeIn";

    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("shop-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
