---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/products";

const products = await getProducts();
---

<Layout title="Shop — Organic Blue">
    <!-- Three product columns, aligned with the navbar shop row above the nav. -->
    <div
        id="shop-stage"
        class="fixed left-0 right-0 top-0 grid grid-cols-3 grid-rows-1 gap-0.5 px-0.5 pt-0.5 text-xs text-black"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        {
            products.map((p) => {
                // Cycle through all product images on hover; distinct URLs only.
                const urls = [...new Set(p.images.map((img) => img.url))];
                return (
                    <a
                        href={`/shop/${p.slug}`}
                        data-flicker
                        data-flicker-step="0.1"
                        data-flicker-ease="power2.out"
                        class="h-full w-full rounded-xs bg-grey overflow-hidden flex items-center justify-center"
                    >
                        {urls[0] ? (
                            <img
                                src={urls[0]}
                                alt={p.images[0]?.alt ?? p.name}
                                data-hover-gallery={JSON.stringify(urls)}
                                class="h-full w-full object-cover"
                            />
                        ) : (
                            <span>{p.name}</span>
                        )}
                    </a>
                );
            })
        }
    </div>
</Layout>

<script>
    import "../scripts/hoverGallery";

    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("shop-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    document.addEventListener("astro:page-load", sizeStage);
    window.addEventListener("resize", sizeStage);
</script>
