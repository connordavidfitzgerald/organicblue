---
import Layout from "../layouts/Layout.astro";

// About section: the "Index" definitions become accordions under the about text.
const aboutAccordions = [
    {
        term: "Organic",
        body: "The primal layer of human experience: learning through the senses, movement, and direct engagement with the natural world. It reflects our innate connection to ecosystems, the body, and the rhythms of the earth, grounding us in presence, calm, and sustainable ways of living.",
    },
    {
        term: "Blue",
        body: "The modern layer of human experience: learning through technology, built environments, and evolving systems that extend human capability. It represents innovation, networks, and the tools that guide progress toward more connected, sustainable, and human-centered futures.",
    },
    {
        term: "Reconnecting with the Organic",
        body: "The foundation where Organic Blue lives. It is not a return to the past, but a reawakening of the sensory intelligence already within us, awareness of the body, movement, environment, and natural rhythms often muted by modern life. By restoring this connection, technology, design, and innovation can operate with intention, creating a balanced state where contemporary systems and human instinct exist in harmony.",
    },
];

// FAQ section.
const faqIntro =
    "Every Organic Blue piece is made to order, by one set of hands, in our studio in Montréal, Québec. Because each item is crafted individually rather than pulled from existing stock, please allow for production time before your order ships (see Production & Shipping Timelines below).";

// TODO: replace placeholder bodies with real copy.
const faqAccordions = [
    {
        term: "Returns",
        body: "We do not accept returns or offer refunds, except in cases where an item arrives damaged. If your order arrives damaged, please contact us within 30 days of delivery with:\n\n- Your order number\n- Photos of the damaged item and packaging.\n\nWe will review your claim and arrange a resolution.",
    },
    {
        term: "Repairs",
        body: "[Placeholder] Add your repairs policy here.",
    },
    {
        term: "Exchanges",
        body: "[Placeholder] Add your exchanges policy here.",
    },
    {
        term: "Production & Shipping Timelines",
        body: "[Placeholder] Add your production & shipping timelines here.",
    },
];

// Lightweight body formatting so accordion copy can mix paragraphs and bullets:
//   • a blank line starts a new paragraph
//   • a line starting with "- " becomes a bullet
type Block = { type: "p"; text: string } | { type: "ul"; items: string[] };

function parseBody(body: string): Block[] {
    const blocks: Block[] = [];
    let para: string[] = [];
    let list: string[] = [];
    const flushPara = () => {
        if (para.length) blocks.push({ type: "p", text: para.join(" ") });
        para = [];
    };
    const flushList = () => {
        if (list.length) blocks.push({ type: "ul", items: list });
        list = [];
    };
    for (const raw of body.split("\n")) {
        const line = raw.trim();
        if (line === "") {
            flushPara();
            flushList();
        } else if (line.startsWith("- ")) {
            flushPara();
            list.push(line.slice(2).trim());
        } else {
            flushList();
            para.push(line);
        }
    }
    flushPara();
    flushList();
    return blocks;
}
---

<Layout title="Organic Blue">
    <div
        id="info-stage"
        class="fixed left-0 right-0 top-0 grid grid-cols-12 gap-0.5 px-0.5 pt-0.5 text-xs text-grey"
        style="bottom: var(--nav-h, 3.5rem);"
    >
        <!-- About -->
        <div class="col-span-3 flex flex-col gap-0.5 h-full">
            <div class="flex w-full px-1 py-1 rounded-xs h-6.5 bg-black">
                About
            </div>
            <div class="flex flex-col px-1 py-1 rounded-xs bg-black">
                Organic Blue is a Montreal-based design studio working across
                technical garments, objects and spatial experiences. Our
                practice is built around a single question: How do the
                environments we move through shape the way we experience
                ourselves?
            </div>
            {
                aboutAccordions.map((item) => (
                    <div class="accordion flex flex-col gap-0.5">
                        <button
                            type="button"
                            class="accordion-header flex items-center justify-between w-full px-1 py-1 rounded-xs h-6.5 bg-black text-grey"
                            aria-expanded="false"
                        >
                            <span>{item.term}</span>
                            <span class="accordion-icon select-none">+</span>
                        </button>
                        <div class="accordion-body hidden space-y-2 px-1 py-1 rounded-xs bg-grey text-black">
                            {parseBody(item.body).map((block) =>
                                block.type === "ul" ? (
                                    <ul class="list-disc pl-4">
                                        {block.items.map((li) => (
                                            <li>{li}</li>
                                        ))}
                                    </ul>
                                ) : (
                                    <p>{block.text}</p>
                                ),
                            )}
                        </div>
                    </div>
                ))
            }
            <!-- Empty filler soaks up the space down to the navbar; shrinks as
                 accordions open. -->
            <div class="grow min-h-0 rounded-xs bg-grey"></div>
        </div>

        <!-- FAQ -->
        <div class="col-span-3 flex flex-col gap-0.5 h-full">
            <div class="flex w-full px-1 py-1 rounded-xs h-6.5 bg-black">
                FAQ
            </div>
            <div class="flex flex-col px-1 py-1 rounded-xs bg-black">
                {faqIntro}
            </div>
            {
                faqAccordions.map((item) => (
                    <div class="accordion flex flex-col gap-0.5">
                        <button
                            type="button"
                            class="accordion-header flex items-center justify-between w-full px-1 py-1 rounded-xs h-6.5 bg-black text-grey"
                            aria-expanded="false"
                        >
                            <span>{item.term}</span>
                            <span class="accordion-icon select-none">+</span>
                        </button>
                        <div class="accordion-body hidden space-y-2 px-1 py-1 rounded-xs bg-grey text-black">
                            {parseBody(item.body).map((block) =>
                                block.type === "ul" ? (
                                    <ul class="list-disc pl-4">
                                        {block.items.map((li) => (
                                            <li>{li}</li>
                                        ))}
                                    </ul>
                                ) : (
                                    <p>{block.text}</p>
                                ),
                            )}
                        </div>
                    </div>
                ))
            }
            <div class="grow min-h-0 rounded-xs bg-grey"></div>
        </div>

        <!-- Contact -->
        <div class="col-span-3 flex flex-col gap-0.5 h-full">
            <div class="flex w-full px-1 py-1 rounded-xs h-6.5 bg-black">
                Contact
            </div>
            <div class="flex flex-col px-1 py-1 grow rounded-xs bg-black">
                info@organicblue000.com
            </div>
        </div>

        <!-- Services -->
        <div class="col-span-3 flex flex-col gap-0.5 h-full">
            <div class="flex w-full px-1 py-1 rounded-xs h-6.5 bg-black">
                Services
            </div>
            <ul class="flex flex-col px-1 py-1 grow rounded-xs bg-black">
                <li>Research.</li>
                <li>Prototyping.</li>
                <li>Concepting.</li>
                <li>World Building.</li>
                <li>Creative Direction.</li>
                <li>Small batch production.</li>
                <li>Technical Product design.</li>
            </ul>
        </div>
    </div>
</Layout>

<script>
    function sizeStage() {
        const nav = document.getElementById("navbar");
        const stage = document.getElementById("info-stage");
        if (!nav || !stage) return;
        stage.style.setProperty("--nav-h", `${nav.offsetHeight}px`);
    }

    function wireAccordions() {
        // Elements are replaced on each navigation, so re-querying here can't
        // stack listeners.
        document
            .querySelectorAll<HTMLButtonElement>(".accordion-header")
            .forEach((btn) => {
                btn.addEventListener("click", () => {
                    const accordion = btn.closest(".accordion");
                    const body =
                        accordion?.querySelector<HTMLElement>(".accordion-body");
                    const icon =
                        btn.querySelector<HTMLElement>(".accordion-icon");
                    if (!body || !icon) return;
                    const open = body.classList.toggle("hidden") === false;
                    icon.textContent = open ? "−" : "+";
                    btn.setAttribute("aria-expanded", String(open));
                });
            });
    }

    document.addEventListener("astro:page-load", () => {
        sizeStage();
        wireAccordions();
    });
    window.addEventListener("resize", sizeStage);
</script>
