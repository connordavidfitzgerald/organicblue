# Shopify Storefront API (headless). From your custom app's API credentials.
# Copy to .env and fill in. Safe to keep the token private; it's read at build time.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=

# Sanity (headless CMS for archive + explorations images).
# projectId + dataset are read at build time and are safe to expose (PUBLIC_).
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
# Editor token used ONLY by scripts/import-to-sanity.mjs to upload/seed content.
# Keep this secret; never referenced by the site at runtime.
SANITY_WRITE_TOKEN=
